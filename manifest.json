{
  "manifest_version": 3,
  "name": "Kibana Magic Beans",
  "version": "1.1.0",
  "description": "Chrome extension for Kibana that makes you feel as powerful as a Super Saiyan that even Bini Jhoanna might notice you.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://kibana-cimb-live.ocft.com.sg/*"],
      "js": ["theme.js"],
      "css": ["dark.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://kibana-cimb-live.ocft.com.sg/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
